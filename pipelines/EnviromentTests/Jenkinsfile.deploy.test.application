pipeline {

    agent any

    environment {
        BASE_URL_APP   = credentialsId('BASE-URL-APP')
        BASE_URL_DB    = credentialsId('BASE-URL-DB')
        MAX_RETRIES    = "10"
        RETRY_INTERVAL = "5"
    }

    stages {
        stage('Verificando se API principal está online!') {
            steps {
                script {
                    echo "Aguardando API principal em ${BASE_URL_APP}..."

                    retry(MAX_RETRIES.toInterger()) {
                        sleep(RETRY_INTERVAL.toInteger())

                        def statusApp = sh (
                            script:  "curl -f -s -o /dev/null -w '%{http_code}' ${BASE_URL_APP}/actuator/health",
                            returnStdout: true
                        ).trim()

                        if (statusApp != '200') {
                            echo "API principal ainda não está pronta. Status: ${statusApp}"
                        }

                        echo "API principal está pronta!"
                    }
                }
            }
        }

        stage('Verificando se API de persistência está online!') {
            steps {
                script {
                    echo "Aguardando API de persistência em ${BASE_URL_DB}..."

                    retry(MAX_RETRIES.toInterger()) {
                        sleep(RETRY_INTERVAL.toInteger())

                        def statusDB = sh (
                            script:  "curl -f -s -o /dev/null -w '%{http_code}' ${BASE_URL_DB}/actuator/health",
                            returnStdout: true
                        ).trim()

                        if (statusDB != '200') {
                            echo "API de persistência ainda não está pronta. Status: ${statusDB}"
                        }

                        echo "API de persistência está pronta!"
                    }
                }
            }
        }

        stage('Verificando Health-Check - Acuator') {
            steps {
                script {
                    echo "Verificando Health da aplicação principal..."

                    sh """
                        HEALTH=\${curl} -s ${BASE_URL_APP}/actuator/health
                        echo "Resposta: \$HEALTH"
                        echo "\$HEALTH | grep -q '"status":"UP"' || { echo 'API principal não está UP'; exit 1; }
                        echo "API principal está UP"
                    """

                    echo "Verificando Health da aplicação de persistência..."


                    sh """
                        HEALTH=\${curl} -s ${BASE_URL_DB}/actuator/health
                        echo "Resposta: \$HEALTH"
                        echo "\$HEALTH | grep -q '"status":"UP"' || { echo 'API de persistência não está UP'; exit 1; }
                        echo "API de persistência está UP"
                    """
                }
            }
        }

        stage('Smoke tests - Endpoints principais') {
            steps {
                script {
                    sh """
                        smokeTest() {
                            DESCRICAO="\$1"
                            ESPERADO="\$2"
                            METODO="\$3"
                            URL="\$4"
                            CORPO="\$5"
 
                            if [ -n "\$CORPO" ]; then
                                STATUS=\$(curl -s -o /dev/null -w '%{http_code}' \
                                    -X \$METODO \
                                    -H 'Content-Type: application/json' \
                                    -d "\$CORPO" \
                                    "\$URL")
                            else
                                STATUS=\$(curl -s -o /dev/null -w '%{http_code}' \
                                    -X \$METODO "\$URL")
                            fi
 
                            if [ "\$STATUS" = "\$ESPERADO" ]; then
                                echo " PASSOU  | \$DESCRICAO | HTTP \$STATUS"
                            else
                                echo " FALHOU  | \$DESCRICAO | Esperado: \$ESPERADO | Recebido: \$STATUS"
                                exit 1
                            fi
                        }

                        echo "──────────────────────────────────────────────"
                        echo " SMOKE TESTS"
                        echo "──────────────────────────────────────────────"

                        smokeTest "GET /api/v1/calc - Listar operações passadas" \
                        "200" "GET" "${BASE_URL_APP}/api/v1/calc"

                        smokeTest "GET /api/v1/calc/prev - Listar operações passadas" \
                        "200" "GET" "${BASE_URL_APP}/api/v1/calc/prev"

                        smokeTest "POST /api/v1/calc/ - Divisão" \
                        "200" "POST" "${BASE_URP_APP} /api/v1/calc" '{ "valor1": "100", "valor2": "20", "tipoDeOperacao": "DIVISAO" }'

                        smokeTest "POST /api/v1/calc/ - Multiplicação" \
                        "200" "POST" "${BASE_URP_APP} /api/v1/calc" '{ "valor1": "100", "valor2": "20", "tipoDeOperacao": "MUTIPLICACAO" }'

                        smokeTest "POST /api/v1/calc/ - Soma" \
                        "200" "POST" "${BASE_URP_APP} /api/v1/calc" '{ "valor1": "100", "valor2": "20", "tipoDeOperacao": "SOMA" }'

                        smokeTest "POST /api/v1/calc/ - Substração" \
                        "200" "POST" "${BASE_URP_APP} /api/v1/calc" '{ "valor1": "100", "valor2": "20", "tipoDeOperacao": "SUBTRACAO" }'

                        smokeTest "POST /api/v1/calc/ - Input inválido retornar erro" \
                        "500" "POST" "${BASE_URP_APP} /api/v1/calc" '{ "valor1": "abc123", "valor2": "20", "tipoDeOperacao": "SUBTRACAO" }'

                        smokeTest "GET /api/v1/calcRepo - Listar operações diretamente do banco" \
                        "200" "POST" "${BASE_URP_DB} /api/v1/calcRepo"

                        smokeTest "GET /api/v1/calcRepo/prev - Listar operações passadas diretamente do banco" \
                        "200" "POST" "${BASE_URP_DB} /api/v1/calcRepo/prev"


                        echo "──────────────────────────────────────────────"
                        echo "Todos os Smoke Tests passaram!"
                        echo "──────────────────────────────────────────────"

                    """
                }
            }
        }

        stage('Teste de Integração - Validação de resultados') {
            steps {
                script {
                    sh sh """
                        assertResult() {
                            DESCRICAO="\$1"
                            CORPO="\$2"
                            RESULTADO_ESPERADO="\$3"
 
                            # Faz a requisição e captura o corpo completo da resposta
                            RESPOSTA=\$(curl -s -X POST \
                                -H 'Content-Type: application/json' \
                                -d "\$CORPO" \
                                "${BASE_URL_APP}/api/v1/calc")
 
                            echo "Resposta recebida: \$RESPOSTA"
 
                            # Verifica se o resultado esperado está contido na resposta
                            # O DTO retorna: {"result":"<valor>"}
                            echo "\$RESPOSTA" | grep -q "\$RESULTADO_ESPERADO" \
                                && echo " PASSOU  | \$DESCRICAO | Resultado: \$RESULTADO_ESPERADO" \
                                || { echo " FALHOU  | \$DESCRICAO | Esperado conter: \$RESULTADO_ESPERADO"; exit 1; }
                        }
 
                        echo "──────────────────────────────────────────────"
                        echo " TESTES DE INTEGRAÇÃO"
                        echo "──────────────────────────────────────────────"
 
                        assertResult "SOMA 10 + 5 = 15.00" \
                            '{"valor1":"10","valor2":"5","tipoDeOperacao":"SOMA"}' "15.00"
 
                        assertResult "SUBTRACAO 20 - 8 = 12.00" \
                            '{"valor1":"20","valor2":"8","tipoDeOperacao":"SUBTRACAO"}' "12.00"
 
                        assertResult "MUTIPLICACAO 4 * 3 = 12.00" \
                            '{"valor1":"4","valor2":"3","tipoDeOperacao":"MUTIPLICACAO"}' "12.00"
 
                        assertResult "DIVISAO 10 / 2 = 5.00" \
                            '{"valor1":"10","valor2":"2","tipoDeOperacao":"DIVISAO"}' "5.00"
 
                        assertResult "SOMA decimal 1.5 + 2.5 = 4.00" \
                            '{"valor1":"1.5","valor2":"2.5","tipoDeOperacao":"SOMA" "4.00"
 
                        assertResult "DIVISAO com arredondamento 10 / 3 = 3.33" \
                            '{"valor1":"10","valor2":"3","tipoDeOperacao":"DIVISAO" "3.33"
 
                        echo "──────────────────────────────────────────────"
                        echo " Todos os Testes de Integração passaram!"
                        echo "──────────────────────────────────────────────"
                    """
                }
            }
        }

        stage('Teste de Persistência - Feign Client') {
            steps {
                script {
                    sh """
                        echo "──────────────────────────────────────────────"
                        echo " TESTE DE PERSISTÊNCIA"
                        echo "──────────────────────────────────────────────"
 
                        echo "Enviando operação para persistir..."
                        curl -s -X POST \
                            -H 'Content-Type: application/json' \
                            -d '{"valor1":"99","valor2":"1","tipoDeOperacao":"SOMA"}' \
                            "${BASE_URL_DB}/api/v1/calc"
 
                        sleep 2
 
                        echo "Verificando operação salva no banco..."
                        PREV=\$(curl -s "${BASE_URL_DB}/api/v1/calc/prev")
                        echo "Última operação: \$PREV"
 
                        echo "\$PREV" | grep -q "100.00" \
                            && echo "Persistência validada! Resultado 100.00 encontrado." \
                            || { echo "Resultado esperado 100.00 não encontrado na persistência!"; exit 1; }
 
                        echo "──────────────────────────────────────────────"
                        echo "Teste de Persistência passou!"
                        echo "──────────────────────────────────────────────"
                    """
                }
            }
        }

        stage('Teste de Carga - Estabilidade básica') {
            steps {
                script {
                    sh """
                        echo "──────────────────────────────────────────────"
                        echo " TESTE DE CARGA LEVE (20 requisições)"
                        echo "──────────────────────────────────────────────"
 
                        FALHAS=0
                        TOTAL=20
 
                        i=1
                        while [ \$i -le \$TOTAL ]; do
                            STATUS=\$(curl -s -o /dev/null -w '%{http_code}' \
                                -X POST \
                                -H 'Content-Type: application/json' \
                                -d '{"valor1":"2","valor2":"2","tipoDeOperacao":"SOMA"}' \
                                "${BASE_URL}/api/v1/calc")
 
                            if [ "\$STATUS" != "200" ]; then
                                echo "Requisição \$i falhou com status \$STATUS"
                                FALHAS=\$((FALHAS + 1))
                            fi
                            i=\$((i + 1))
                        done
 
                        echo ""
                        echo "Resultado: \$((TOTAL - FALHAS))/\$TOTAL requisições bem-sucedidas"

                        LIMITE=2
                        if [ \$FALHAS -gt \$LIMITE ]; then
                            echo "Muitas falhas: \$FALHAS (limite: \$LIMITE)"
                            exit 1
                        fi
 
                        echo "──────────────────────────────────────────────"
                        echo "Teste de carga passou! Falhas: \$FALHAS/\$TOTAL"
                        echo "──────────────────────────────────────────────"
                    """
                }
            }
        }
    }

    post {
        always {
            echo "Pipeline de testes finalizado."
            echo "API Principal : ${BASE_URL_APP}"
            echo "API Persistência: ${BASE_URL_DB}"
        }
 
        success {
            echo """
            ╔══════════════════════════════════════╗
            ║  TODOS OS TESTES PASSARAM            ║
            ║  A aplicação está saudável!          ║
            ╚══════════════════════════════════════╝
            """
        }
 
        failure {
            echo "Testes falharam — derrubando ambiente para evitar estado inconsistente."
            sh """
                docker-compose -f compose/Servers/Application/docker-compose.yml down -v || true
                echo "Containers derrubados."
            """
        }
    }
}